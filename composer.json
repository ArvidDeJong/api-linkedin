{
    "name": "darvis/api-linkedin",
    "description": "Universele Laravel-koppeling om berichten op LinkedIn te plaatsen (persoonlijk profiel én bedrijfspagina) via OAuth 2.0 en de Posts API.",
    "keywords": [
        "laravel",
        "linkedin",
        "oauth",
        "posts-api",
        "social",
        "share"
    ],
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "authors": [
        {
            "name": "Arvid de Jong",
            "email": "info@arvid.nl"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Darvis\\ApiLinkedin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Darvis\\ApiLinkedin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Darvis\\ApiLinkedin\\LinkedInServiceProvider"
            ],
            "aliases": {
                "LinkedIn": "Darvis\\ApiLinkedin\\Facades\\LinkedIn"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest"
    }
}
